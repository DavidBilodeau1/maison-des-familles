APP_NAME=Photoshoot
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=photo_selection
DB_USERNAME=photo_user
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ============================================
# PHOTOSHOOT CUSTOMIZATION
# ============================================

# Branding
PHOTOSHOOT_APP_NAME="Photoselection"
PHOTOSHOOT_ORG_NAME="Photoselection"
PHOTOSHOOT_ORG_DESC="A photoselection app"
PHOTOSHOOT_ORG_TAGLINE="A photoselection app"
PHOTOSHOOT_LOGO_PATH="images/logo.png"
PHOTOSHOOT_LOGO_HEIGHT="h-14"

# Color Scheme (Tailwind CSS colors: purple, blue, pink, green, red, yellow, indigo, etc.)
PHOTOSHOOT_COLOR_PRIMARY="blue"
PHOTOSHOOT_COLOR_SECONDARY="teal"
PHOTOSHOOT_GRADIENT_START="#667eea"
PHOTOSHOOT_GRADIENT_END="#764ba2"
PHOTOSHOOT_WARM_GRADIENT_START="#f093fb"
PHOTOSHOOT_WARM_GRADIENT_END="#f5576c"

# Session Settings
PHOTOSHOOT_SESSION_DURATION=30
PHOTOSHOOT_PIN_LENGTH=8

# Admin Settings (CHANGE THIS PASSWORD!)
PHOTOSHOOT_ADMIN_PASSWORD="admin123"

# Storage Paths
PHOTOSHOOT_STORAGE_BASE="photos"
PHOTOSHOOT_STORAGE_UPLOADS="uploads"
PHOTOSHOOT_STORAGE_FINAL="final_choices"

# UI Text & Messages (customize for your language/organization)
PHOTOSHOOT_WELCOME_TITLE="Welcome! 👋"
PHOTOSHOOT_WELCOME_SUBTITLE="Family Photo Selection"
PHOTOSHOOT_LOGIN_INSTRUCTIONS="📸 It's time to choose your favorite photos!"
PHOTOSHOOT_VIEW_PHOTOS_BTN="🎉 View My Photos"
PHOTOSHOOT_SUBMIT_BTN="Submit My Selections"

# Feature Flags
PHOTOSHOOT_SHOW_FOOTER=true
PHOTOSHOOT_ENABLE_EMOJIS=true
PHOTOSHOOT_SHOW_TIMER=true
